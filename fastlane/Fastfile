require "base64"
require "fileutils"
require "securerandom"
require "shellwords"

default_platform(:ios)

def required_env(name)
  value = ENV[name]
  UI.user_error!("Missing required environment variable: #{name}") if value.to_s.strip.empty?
  value.to_s.strip
end

def app_identifier
  ENV.fetch("APP_IDENTIFIER", "com.fleetscanai.app")
end

def app_version
  ENV.fetch("APP_VERSION", "1.0")
end

def build_number
  explicit = ENV["APP_BUILD_NUMBER"].to_s.strip
  return explicit unless explicit.empty?

  ENV["GITHUB_RUN_NUMBER"] || Time.now.utc.strftime("%Y%m%d%H%M")
end

def bool_env(name)
  ENV[name].to_s.downcase == "true"
end

def review_text_file(name)
  path = File.expand_path("../fastlane/metadata/review_information/#{name}.txt", __dir__)
  File.exist?(path) ? File.read(path).strip : ""
end

def app_review_information
  {
    first_name: review_text_file("first_name"),
    last_name: review_text_file("last_name"),
    phone_number: review_text_file("phone_number"),
    email_address: review_text_file("email_address"),
    notes: review_text_file("notes")
  }
end

def asc_key_path
  key_id = required_env("APP_STORE_CONNECT_API_KEY_ID")
  key_content = asc_key_content
  key_dir = File.expand_path("~/.appstoreconnect/private_keys")
  FileUtils.mkdir_p(key_dir)
  key_path = File.join(key_dir, "AuthKey_#{key_id}.p8")
  File.write(key_path, key_content)
  File.chmod(0o600, key_path)
  key_path
end

def asc_key_content
  base64_content = ENV["APP_STORE_CONNECT_API_KEY_P8_BASE64"].to_s.strip
  return Base64.strict_decode64(base64_content).strip unless base64_content.empty?

  required_env("APP_STORE_CONNECT_API_KEY_P8").gsub("\\n", "\n").strip
end

def asc_key_content_base64
  base64_content = ENV["APP_STORE_CONNECT_API_KEY_P8_BASE64"].to_s.strip
  return base64_content unless base64_content.empty?

  Base64.strict_encode64(asc_key_content)
end

def asc_api_key
  app_store_connect_api_key(
    key_id: required_env("APP_STORE_CONNECT_API_KEY_ID"),
    issuer_id: required_env("APP_STORE_CONNECT_ISSUER_ID"),
    key_content: asc_key_content_base64,
    is_key_content_base64: true,
    duration: 1200,
    in_house: false
  )
end

def ci_python
  venv_root = File.expand_path("../.ci-venv", __dir__)
  python_path = Gem.win_platform? ? File.join(venv_root, "Scripts", "python.exe") : File.join(venv_root, "bin", "python")
  sh("python3 -m venv #{Shellwords.escape(venv_root)}") unless File.exist?(python_path)
  python_path
end

def distribution_certificate_p12_path
  base64_content = ENV["APPLE_DISTRIBUTION_CERTIFICATE_P12_BASE64"].to_s.strip
  return nil if base64_content.empty?

  p12_path = File.expand_path("../.ci-distribution-certificate.p12", __dir__)
  File.binwrite(p12_path, Base64.strict_decode64(base64_content))
  p12_path
end

def prepare_app_store_signing(api_key, team_id)
  keychain_password = ENV.fetch("CI_KEYCHAIN_PASSWORD", SecureRandom.hex(24))
  keychain_name = "fleetscanai-build.keychain"
  keychain_path = File.expand_path("~/Library/Keychains/#{keychain_name}-db")

  if ENV["CI"].to_s.downcase == "true"
    create_keychain(
      name: keychain_name,
      password: keychain_password,
      default_keychain: true,
      unlock: true,
      timeout: 3600,
      lock_when_sleeps: false
    )
  end

  p12_path = distribution_certificate_p12_path
  if p12_path
    import_certificate(
      certificate_path: p12_path,
      certificate_password: required_env("APPLE_DISTRIBUTION_CERTIFICATE_PASSWORD"),
      keychain_name: keychain_name,
      keychain_password: keychain_password
    )
    FileUtils.rm_f(p12_path)
  end

  get_certificates(
    api_key: api_key,
    team_id: team_id,
    development: false,
    generate_apple_certs: true,
    keychain_path: keychain_path,
    keychain_password: keychain_password
  )
  cert_id = Actions.lane_context[SharedValues::CERT_CERTIFICATE_ID]

  get_provisioning_profile(
    api_key: api_key,
    team_id: team_id,
    app_identifier: app_identifier,
    cert_id: cert_id,
    force: true,
    provisioning_name: "FleetScan AI App Store"
  )

  profile_name = Actions.lane_context[SharedValues::SIGH_NAME]
  UI.user_error!("Unable to resolve App Store provisioning profile name.") if profile_name.to_s.strip.empty?
  profile_name
end

platform :ios do
  before_all do
    python = Shellwords.escape(ci_python)
    asset_script = Shellwords.escape(File.expand_path("../Tools/create_appstore_assets.py", __dir__))
    submission_script = Shellwords.escape(File.expand_path("../Tools/prepare_fastlane_submission.py", __dir__))
    sh("#{python} -m pip install --upgrade pip")
    sh("#{python} -m pip install pillow")
    sh("#{python} #{asset_script}")
    sh("#{python} #{submission_script}")
  end

  desc "Upload App Store metadata, screenshots, and app icon"
  lane :upload_metadata do
    skip_screenshots = bool_env("SKIP_SCREENSHOTS")

    deliver(
      api_key: asc_api_key,
      app_identifier: app_identifier,
      app_version: app_version,
      metadata_path: "fastlane/metadata",
      screenshots_path: "fastlane/screenshots",
      app_icon: "fastlane/metadata/app_icon.png",
      skip_binary_upload: true,
      skip_metadata: false,
      skip_screenshots: skip_screenshots,
      submit_for_review: false,
      force: true,
      overwrite_screenshots: !skip_screenshots,
      run_precheck_before_submit: false
    )
  end

  desc "Archive and export a signed App Store IPA"
  lane :build_appstore do
    team_id = required_env("APPLE_TEAM_ID")
    api_key = asc_api_key
    profile_name = prepare_app_store_signing(api_key, team_id)
    key_path = asc_key_path
    escaped_key_path = Shellwords.escape(key_path)
    profile_arg = Shellwords.escape("PROVISIONING_PROFILE_SPECIFIER=#{profile_name}")

    build_app(
      project: "FleetScanAI.xcodeproj",
      scheme: "FleetScanAI",
      configuration: "Release",
      clean: true,
      output_directory: "build",
      output_name: "FleetScanAI.ipa",
      export_method: "app-store",
      xcargs: [
        "-allowProvisioningUpdates",
        "-authenticationKeyPath #{escaped_key_path}",
        "-authenticationKeyID #{required_env('APP_STORE_CONNECT_API_KEY_ID')}",
        "-authenticationKeyIssuerID #{required_env('APP_STORE_CONNECT_ISSUER_ID')}",
        "DEVELOPMENT_TEAM=#{team_id}",
        "PRODUCT_BUNDLE_IDENTIFIER=#{app_identifier}",
        "MARKETING_VERSION=#{app_version}",
        "CURRENT_PROJECT_VERSION=#{build_number}",
        "CODE_SIGN_STYLE=Manual",
        "CODE_SIGN_IDENTITY=Apple\\ Distribution",
        profile_arg
      ].join(" "),
      export_options: {
        method: "app-store",
        signingStyle: "manual",
        signingCertificate: "Apple Distribution",
        teamID: team_id,
        provisioningProfiles: {
          app_identifier => profile_name
        },
        manageAppVersionAndBuildNumber: false,
        uploadSymbols: true,
        stripSwiftSymbols: true
      }
    )
  end

  desc "Upload the exported IPA to App Store Connect/TestFlight"
  lane :upload_build do
    upload_to_testflight(
      api_key: asc_api_key,
      app_identifier: app_identifier,
      ipa: "build/FleetScanAI.ipa",
      skip_waiting_for_build_processing: false
    )
  end

  desc "Submit the prepared app version for App Review after the build is processed"
  lane :submit_review do
    UI.user_error!("Set CONFIRM_SUBMIT_FOR_REVIEW=true to submit for App Review.") unless bool_env("CONFIRM_SUBMIT_FOR_REVIEW")
    UI.user_error!("Set OWNER_CONFIRMED_PRIVACY=true after confirming App Privacy answers.") unless bool_env("OWNER_CONFIRMED_PRIVACY")
    UI.user_error!("Set OWNER_CONFIRMED_DSA=true after completing DSA trader status in App Store Connect.") unless bool_env("OWNER_CONFIRMED_DSA")
    UI.user_error!("Set OWNER_CONFIRMED_EXPORT=true after confirming export compliance answers.") unless bool_env("OWNER_CONFIRMED_EXPORT")
    UI.user_error!("Set OWNER_CONFIRMED_CONTENT_RIGHTS=true after confirming content rights.") unless bool_env("OWNER_CONFIRMED_CONTENT_RIGHTS")

    deliver(
      api_key: asc_api_key,
      app_identifier: app_identifier,
      app_version: app_version,
      skip_binary_upload: true,
      skip_metadata: true,
      skip_screenshots: true,
      submit_for_review: true,
      automatic_release: false,
      build_number: build_number,
      app_review_information: app_review_information,
      run_precheck_before_submit: true,
      precheck_include_in_app_purchases: false,
      submission_information: {
        add_id_info_uses_idfa: false,
        export_compliance_uses_encryption: false,
        content_rights_contains_third_party_content: false
      }
    )
  end

  desc "Prepare assets, upload metadata, build, and upload IPA"
  lane :release_upload do
    upload_metadata
    build_appstore
    upload_build
  end
end
